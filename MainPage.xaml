<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SyncShoppingList.Mobile.MainPage"
             Title="Список покупок"
             BackgroundColor="#1E1E1E">

    <Grid RowDefinitions="Auto,*,Auto">
        
        <Label Grid.Row="0" Text="🛒 Список покупок" 
               FontSize="22" 
               FontAttributes="Bold"
               HorizontalOptions="Center" 
               Margin="10"
               TextColor="#FFFFFF"/>

        <CollectionView Grid.Row="1" 
                        x:Name="ProductsList" 
                        Margin="10,0">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Grid ColumnDefinitions="Auto,*,Auto" Margin="0,3">
                        <CheckBox Grid.Column="0"
                                  IsChecked="{Binding IsPurchased}"
                                  HorizontalOptions="Start"/>
                        <Label Grid.Column="1" 
                               Text="{Binding Name}" 
                               TextColor="#FFFFFF" 
                               FontSize="16"
                               Margin="10,0"/>
                        <Button Grid.Column="2" 
                                Text="🗑️" 
                                BackgroundColor="Transparent" 
                                TextColor="#FF4444"
                                Clicked="OnDeleteClicked"
                                CommandParameter="{Binding Id}"/>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Grid Grid.Row="2" ColumnDefinitions="*,Auto" Margin="10">
            <Entry x:Name="ProductEntry" 
                   Placeholder="Новый продукт..." 
                   TextColor="#FFFFFF"
                   BackgroundColor="#3A3A3A"/>
            <Button Grid.Column="1" 
                    Text="➕"
                    BackgroundColor="#2E4A7A"
                    TextColor="#FFFFFF"
                    Clicked="OnAddClicked"/>
        </Grid>
        
    </Grid>
</ContentPage>