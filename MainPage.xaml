<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SyncShoppingList.Mobile.MainPage"
             BackgroundColor="{StaticResource BackgroundColor}">

    <Grid RowDefinitions="Auto,*,Auto">
        
        <!-- Заголовок -->
        <Grid Grid.Row="0" BackgroundColor="{StaticResource PrimaryDarkColor}">
            <VerticalStackLayout Padding="20,30,20,20">
                <Label Text="SyncShop" Style="{StaticResource TitleLabel}" FontSize="28" HorizontalOptions="Center"/>
                <Label x:Name="GroupInfoLabel" Text="Список покупок" Style="{StaticResource SubtitleLabel}" HorizontalOptions="Center"/>
            </VerticalStackLayout>
        </Grid>
        
        <!-- Список продуктов -->
        <CollectionView Grid.Row="1" x:Name="ProductsList" Margin="15,20" VerticalScrollBarVisibility="Never">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Margin="0,5" 
                           Padding="10" 
                           BackgroundColor="{StaticResource SurfaceColor}" 
                           CornerRadius="15"
                           HasShadow="False">
                        <Grid ColumnDefinitions="Auto,*,Auto">
                            
                            <CheckBox Grid.Column="0" 
                                      IsChecked="{Binding IsPurchased}"
                                      HorizontalOptions="Start"
                                      VerticalOptions="Center"/>
                            
                            <Label Grid.Column="1" 
                                   Text="{Binding Name}" 
                                   TextColor="{StaticResource TextColor}" 
                                   FontSize="16"
                                   VerticalOptions="Center"
                                   Margin="15,0"/>
                            
                            <Button Grid.Column="2" 
                                    Text="🗑️" 
                                    BackgroundColor="Transparent" 
                                    TextColor="#FF6B6B"
                                    FontSize="18"
                                    Clicked="OnDeleteClicked"
                                    CommandParameter="{Binding Id}"
                                    WidthRequest="40"
                                    VerticalOptions="Center"/>
                        </Grid>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
        
        <!-- Кнопка добавления -->
        <Button Grid.Row="2" 
                Text="➕ Добавить продукт" 
                HorizontalOptions="Center" 
                VerticalOptions="Center"
                WidthRequest="200"
                Margin="0,0,0,20"
                Clicked="OnAddProductClicked">
            <Button.Background>
                <LinearGradientBrush EndPoint="0,1">
                    <GradientStop Color="{StaticResource PrimaryColor}" Offset="0"/>
                    <GradientStop Color="#3D6CB0" Offset="1"/>
                </LinearGradientBrush>
            </Button.Background>
        </Button>
        
    </Grid>
</ContentPage>