<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SyncShoppingList.Mobile.SettingsPage"
             BackgroundColor="{StaticResource BackgroundColor}"
             Shell.NavBarIsVisible="False">

    <Grid>
        
        <!-- Фоновый градиент -->
        <Grid.Background>
            <LinearGradientBrush EndPoint="0,1">
                <GradientStop Color="{StaticResource PrimaryDarkColor}" Offset="0"/>
                <GradientStop Color="{StaticResource BackgroundColor}" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>
        
        <!-- Прокручиваемое содержимое -->
        <ScrollView>
            <VerticalStackLayout Spacing="25" Margin="30,60,30,30">
                
                <!-- Логотип / Заголовок -->
                <HorizontalStackLayout Spacing="10" HorizontalOptions="Center">
                    <Label Text="🛒" FontSize="40" TextColor="{StaticResource SecondaryColor}"/>
                    <Label Text="SyncShop" Style="{StaticResource TitleLabel}" FontSize="32"/>
                </HorizontalStackLayout>
                
                <Label Text="Общий список покупок" 
                       Style="{StaticResource SubtitleLabel}" 
                       HorizontalOptions="Center"
                       Margin="0,0,0,30"/>
                
                <!-- Разделитель -->
                <BoxView HeightRequest="2" BackgroundColor="{StaticResource PrimaryColor}" Margin="40,0"/>
                
                <!-- Секция Создать группу -->
                <VerticalStackLayout Spacing="15" Margin="0,20,0,0">
                    
                    <Label Text="✨ Новая группа" FontSize="20" FontAttributes="Bold" TextColor="{StaticResource TextColor}"/>
                    
                    <Entry x:Name="CreateNickEntry" Placeholder="Ваше имя">
                        <Entry.Triggers>
                            <DataTrigger TargetType="Entry" Binding="{Binding Text.Length}" Value="0">
                                <Setter Property="Placeholder" Value="Ваше имя"/>
                            </DataTrigger>
                        </Entry.Triggers>
                    </Entry>
                    
                    <Entry x:Name="CreateGroupNameEntry" Placeholder="Название группы"/>
                    
                    <Button Text="🚀 Создать группу" Clicked="OnCreateGroupClicked">
                        <Button.Background>
                            <LinearGradientBrush EndPoint="0,1">
                                <GradientStop Color="{StaticResource PrimaryColor}" Offset="0"/>
                                <GradientStop Color="#3D6CB0" Offset="1"/>
                            </LinearGradientBrush>
                        </Button.Background>
                    </Button>
                    
                </VerticalStackLayout>
                
                <!-- Разделитель -->
                <BoxView HeightRequest="1" BackgroundColor="#3A3A3A" Margin="20,10"/>
                
                <!-- Секция Присоединиться -->
                <VerticalStackLayout Spacing="15">
                    
                    <Label Text="🔗 Присоединиться" FontSize="20" FontAttributes="Bold" TextColor="{StaticResource TextColor}"/>
                    
                    <Entry x:Name="JoinNickEntry" Placeholder="Ваше имя"/>
                    <Entry x:Name="JoinCodeEntry" Placeholder="Код приглашения"/>
                    
                    <Button Text="🔗 Присоединиться" 
                            Clicked="OnJoinGroupClicked"
                            BackgroundColor="Transparent"
                            BorderColor="{StaticResource PrimaryColor}"
                            BorderWidth="2"/>
                    
                </VerticalStackLayout>
                
                <!-- Индикатор загрузки -->
                <ActivityIndicator x:Name="LoadingIndicator" IsVisible="False" Color="{StaticResource SecondaryColor}"/>
                
            </VerticalStackLayout>
        </ScrollView>
        
    </Grid>
</ContentPage>